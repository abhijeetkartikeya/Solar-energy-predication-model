# ==============================================================================
# Solar Energy Forecasting System — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# ==============================================================================

# ── InfluxDB Configuration ────────────────────────────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=my-super-secret-token
INFLUXDB_ORG=solar_org
INFLUXDB_BUCKET=solar_bucket
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=admin12345

# ── Grafana Configuration ─────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── Default Solar Plant ───────────────────────────────────────────────────────
DEFAULT_PLANT_NAME=Dhuaran2
DEFAULT_LATITUDE=22.25
DEFAULT_LONGITUDE=72.74

# ── Application Settings ──────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Model Settings ────────────────────────────────────────────────────────────
MODEL_DIR=/app/models
PLANTS_FILE=/app/data/plants.json
